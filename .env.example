# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Twilio ─────────────────────────────────────────────────────────────────────
# Get these from: https://console.twilio.com
# Twilio is used for:
#   1. Masked proxy calls  (scanner ↔ owner, neither sees real number)
#   2. SMS fallback alerts (when WhatsApp fails)
#   3. WhatsApp Business messages (via Twilio WhatsApp sandbox or approved sender)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+12345678901          # Your Twilio SMS/voice number
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886  # Twilio sandbox or your WA Business number
TWILIO_PROXY_SERVICE_SID=KSxxxxxxxxxxxxxxx   # From Twilio Console → Proxy → Services (optional but recommended for call masking)

# ── Emergency Services ────────────────────────────────────────────────────────
# Local ambulance / rescue number to SMS on accident alerts
AMBULANCE_SMS_NUMBER=+921122              # Pakistan Rescue 1122 (use your country's)

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
